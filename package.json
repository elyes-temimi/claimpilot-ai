{
  "name": "claimpilot-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "ClaimPilot AI — Intelligent eKYC + Smart Policy Selection (hackathon prototype)",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:https": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"vite --mode https\"",
    "dev:client": "vite",
    "dev:server": "node server/index.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "postinstall": "node scripts/copy-models.mjs"
  },
  "dependencies": {
    "@vladmandic/face-api": "^1.7.15",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tesseract.js": "^6.0.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "typescript": "~5.6.3",
    "vite": "^6.0.7"
  }
}
