node_modules/
dist/
public/models/
*.local
.DS_Store

# Spooled case data written when MySQL is unreachable. Contains real
# statements, GPS coordinates and driver names — never commit it.
.data/

# Full database dumps may contain case data. db/schema.sql (structure only)
# is intentionally tracked; data dumps are not.
db/full-dump.sql
db/*-data.sql

# Local env / secrets
.env
.env.*
!.env.example

# Python (ekyc-streamlit)
__pycache__/
*.py[cod]
.venv/
venv/

# Logs
*.log
npm-debug.log*

# Self-signed dev certificates generated by @vitejs/plugin-basic-ssl
.cert/
*.pem
